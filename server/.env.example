# Copiez ce fichier en .env et adaptez les valeurs.

# Connexion MySQL (créez la base : CREATE DATABASE sortiespourpetits;)
DATABASE_URL="mysql://sortiespourpetits_API:password@localhost:3306/sortiespourpetits"

# Secret de signature des sessions (générez-en un : openssl rand -hex 32)
JWT_SECRET="changez-moi"

# Port de l'API
PORT=3000

# À positionner à "production" sur le serveur : active les cookies "secure"
# (HTTPS uniquement) et la prise en compte du reverse proxy (IP, protocole).
NODE_ENV=development

# --- Uniquement pour le seed de production (npm run db:seed:prod) ---
# Ne jamais mettre le mot de passe en clair ici. Générez le hash localement :
#   npm run hash-password -- 'mon-mot-de-passe'
# et collez le résultat dans ADMIN_PASSWORD_HASH.
ADMIN_EMAIL="admin@exemple.fr"
ADMIN_PASSWORD_HASH="$2b$12$ifbWpetV6ZHbF2puIywVjO62yV8DPt/urwijrzadvEL60H/K231Ay"
ADMIN_DISPLAY_NAME="Admin"
